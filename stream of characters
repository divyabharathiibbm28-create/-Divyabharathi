class StreamChecker:
    def __init__(self, words: List[str]):
        self.trie = {}
        self.stream = []
        # Maximum length of a word to prevent checking the entire stream
        self.max_len = 0
        
        for word in words:
            self.max_len = max(self.max_len, len(word))
            node = self.trie
            # Store words in REVERSE order
            for char in reversed(word):
                if char not in node:
                    node[char] = {}
                node = node[char]
            node['#'] = True # Mark end of word

    def query(self, letter: str) -> bool:
        self.stream.append(letter)
        
        # Only check up to the maximum word length
        if len(self.stream) > self.max_len:
            self.stream.pop(0)
            
        node = self.trie
        # Check the stream backwards (most recent first)
        for i in range(len(self.stream) - 1, -1, -1):
            char = self.stream[i]
            if char not in node:
                break
            node = node[char]
            if '#' in node:
                return True
        return False
